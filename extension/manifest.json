{
  "manifest_version": 3,
  "name": "Elvar Companion",
  "version": "1.1",
  "description": "Send open tabs to Elvar and launch workflows.",
  "permissions": ["tabs", "contextMenus"],
  "host_permissions": ["http://127.0.0.1:31337/"],
  "icons": {
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  }
}
